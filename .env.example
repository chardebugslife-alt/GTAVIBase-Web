# ---------------------------------------------------------------------------
# GTA VI Base — environment variables
#
# Copy this file to `.env.local` and fill in the values you need.
# Every variable here is prefixed with NEXT_PUBLIC_ because it is read in the
# browser. None of these are secrets — AdSense ids are safe to expose publicly.
# ---------------------------------------------------------------------------

# Canonical site URL (no trailing slash). Used for metadata, sitemap & OG tags.
NEXT_PUBLIC_SITE_URL=https://www.gtavibase.com

# ---------------------------------------------------------------------------
# Google AdSense
#
# Leave NEXT_PUBLIC_ADSENSE_CLIENT empty to disable ads entirely: no AdSense
# script loads and no ad slots render (a clean, ad-free site).
#
# 1. Create an account at https://adsense.google.com and get your site approved.
# 2. Your publisher id is shown as `ca-pub-XXXXXXXXXXXXXXXX`.
# 3. Create ad units (Ads -> By ad unit) and copy each unit's numeric slot id
#    into the matching variable below.
# ---------------------------------------------------------------------------

# Publisher id — enables ads. Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=

# Wide banner unit shown site-wide above the footer (Display ad, horizontal).
NEXT_PUBLIC_ADSENSE_SLOT_HORIZONTAL=

# Tall vertical unit for a side rail (Display ad, vertical).
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Fluid in-article unit shown inside news articles (In-article ad).
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
